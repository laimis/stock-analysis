{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "outDir": "../out-tsc/app",
        "module": "es2015",
        "types": []
    },
    "exclude": [
        "src/test.ts",
        "**/*.spec.ts"
    ],
    "angularCompilerOptions": {
      "extendedDiagnostics": {
        "checks": {
          "nullishCoalescingNotNullable": "suppress",
          "optionalChainNotNullable": "suppress"
        }
      }
    }
}
